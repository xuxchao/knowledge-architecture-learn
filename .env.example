# 阿里千问（DashScope）API 配置 — 模板文件
# 复制本文件为 .env 并填入真实值

# DashScope API Key（从 https://dashscope.console.aliyun.com/ 获取）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# DashScope OpenAI 兼容模式 Base URL
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认使用的模型名称（可选: qwen-turbo, qwen-plus, qwen-max）
DASHSCOPE_MODEL=qwen-plus

# PostgreSQL 连接串（08-postgres-checkpoint 使用）
POSTGRES_CONNECTION_STRING=postgresql://admin:password@localhost:5432/knowledge-architecture
